{
  "name": "top",
  "layer": "top",
  "position": "top",
  "height": 36,
  "margin-top": 8,
  "margin-left": 14,
  "margin-right": 14,
  "spacing": 8,
  "exclusive": true,
  "modules-left": ["custom/workspaces", "custom/logo", "clock", "mpris"],
  "modules-center": ["custom/center"],
  "modules-right": ["custom/profile", "network", "pulseaudio", "battery", "tray", "custom/power"],
  "custom/workspaces": {"exec": "tokyo-niri-workspaces", "interval": 2, "return-type": "json", "on-click": "tokyo-niri-window-menu", "tooltip": "Click: switch window • Super+O: overview"},
  "custom/logo": {"format": "◆", "tooltip": "Launcher", "on-click": "fuzzel"},
  "clock": {"format": "{:%a %d.%m.  %H:%M}", "tooltip-format": "{:%A, %d. %B %Y}", "on-click": "zenity --calendar --text=\"\" --title=\"Calendar\" 2>/dev/null"},
  "mpris": {"format": "♪ {title}", "format-paused": "⏸ {title}", "format-disconnected": "", "max-length": 45, "on-click": "playerctl play-pause", "on-click-right": "playerctl next"},
  "custom/center": {"exec": "tokyo-niri-center", "return-type": "json"},
  "network": {"format-wifi": "wifi {essid}", "format-ethernet": "wired", "format-disconnected": "offline", "tooltip-format": "{ifname}", "on-click": "tokyo-niri-wifi-menu"},
  "pulseaudio": {"format": "vol {volume}%", "format-muted": "muted", "on-click": "tokyo-niri-audio", "tooltip": "Click: adjust volume"},
  "battery": {"states": {"warning": 30, "critical": 15}, "format": "bat {capacity}%", "format-charging": "chg {capacity}%", "format-plugged": "ac {capacity}%", "tooltip-format": "{capacity}% • {power}W\n{timeTo}"},
  "custom/profile": {"exec": "tokyo-niri-tlp-profile", "interval": 30, "format": "{}", "on-click": "tokyo-niri-profile-menu", "tooltip": "Click: switch power profile"},
  "tray": {"spacing": 10},
  "custom/power": {"format": "⏻", "tooltip": "Click: lock / logout / suspend / shutdown / reboot", "on-click": "tokyo-niri-power-menu"}
}
