#!/bin/bash
# Tokyo Night Pro - TLP Profile Switcher
# Manages three power profiles: powersave, balanced, performance

PROFILE="${1:-}"
STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/tokyo-niri-tlp-profile"

# `menu` — fuzzel picker (used by the waybar battery / power-profile click).
# Prefers power-profiles-daemon (no sudo needed); falls back to the
# cpupower/tlp path below.
if [ "$PROFILE" = "menu" ]; then
    command -v fuzzel >/dev/null 2>&1 || { notify-send "power" "fuzzel not installed" 2>/dev/null || true; exit 1; }
    choice=$(printf '❄ powersave\n◈ balanced\n⚡ performance' \
        | fuzzel --dmenu --prompt "profile " --width 30 --lines 3 2>/dev/null) || exit 0
    choice="${choice#* }"
    [ -n "$choice" ] || exit 0
    if command -v powerprofilesctl >/dev/null 2>&1; then
        case "$choice" in
            powersave)   powerprofilesctl set power-saver ;;
            balanced)    powerprofilesctl set balanced ;;
            performance) powerprofilesctl set performance ;;
        esac
        echo "$choice" > "$STATE_FILE"
        notify-send -t 2000 "Power Profile: $choice" 2>/dev/null || true
        exit 0
    fi
    exec "$0" "$choice"
fi

if [ -z "$PROFILE" ]; then
    current=$(cat "$STATE_FILE" 2>/dev/null || echo "balanced")
    case "$current" in
        powersave) echo "❄ powersave" ;;
        balanced) echo "◈ balanced" ;;
        performance) echo "⚡ performance" ;;
        *) echo "◈ $current" ;;
    esac
    exit 0
fi

case "$PROFILE" in
    powersave|balanced|performance) ;;
    *) echo "Usage: $0 {powersave|balanced|performance}"; exit 1 ;;
esac

echo "$PROFILE" > "$STATE_FILE"

# CPU governor
case "$PROFILE" in
    powersave) sudo cpupower frequency-set -g powersave 2>/dev/null ;;
    balanced) sudo cpupower frequency-set -g ondemand 2>/dev/null ;;
    performance) sudo cpupower frequency-set -g performance 2>/dev/null ;;
esac

# Energy Performance Preference (intel_pstate)
case "$PROFILE" in
    powersave) epp="power" ;;
    balanced) epp="balance_power" ;;
    performance) epp="performance" ;;
esac

for cpu in /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference; do
    echo "$epp" | sudo tee "$cpu" >/dev/null 2>/dev/null || true
done

# Max frequency limit for powersave
max_freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null || echo 0)
if [ "$max_freq" -gt 0 ]; then
    if [ "$PROFILE" = "powersave" ]; then
        echo $((max_freq * 75 / 100)) | sudo tee /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq >/dev/null 2>/dev/null || true
    else
        echo "$max_freq" | sudo tee /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq >/dev/null 2>/dev/null || true
    fi
fi

# TLP
if command -v tlp >/dev/null 2>&1; then
    if [ "$PROFILE" = "performance" ]; then
        sudo tlp ac 2>/dev/null
    else
        sudo tlp bat 2>/dev/null
    fi
fi

notify-send -t 2000 "Power Profile: $PROFILE" 2>/dev/null || true
