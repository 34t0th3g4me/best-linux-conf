#!/bin/bash
# Tokyo Night Pro - Power Profile Menu

choice=$(printf "❄ powersave\n◈ balanced\n⚡ performance" | fuzzel --dmenu --prompt "profile" --width 28 --lines 3 2>/dev/null)

case "$choice" in
    *powersave) tokyo-niri-tlp-profile powersave ;;
    *balanced) tokyo-niri-tlp-profile balanced ;;
    *performance) tokyo-niri-tlp-profile performance ;;
esac
