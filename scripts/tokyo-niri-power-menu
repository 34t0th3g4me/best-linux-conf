#!/usr/bin/env bash
# Tokyo Night Pro - Power Menu
# Hardened for waybar 2026: set -euo pipefail, fuzzel click-hijacking fix.
set -euo pipefail

entries="Lock\nLogout\nSuspend\nShutdown\nReboot"

choice=$(sleep 0.1 && printf "%b" "$entries" | fuzzel --dmenu --prompt "power" --width 30 --lines 5 2>/dev/null) || choice=""

command -v fuzzel >/dev/null 2>&1 || { notify-send "power" "fuzzel not installed" 2>/dev/null || true; exit 1; }

case "$choice" in
    Lock)
        loginctl lock-session 2>/dev/null || true
        ;;
    Logout)
        niri msg action quit 2>/dev/null || true
        ;;
    Suspend)
        systemctl suspend 2>/dev/null || true
        ;;
    Shutdown)
        systemctl poweroff 2>/dev/null || true
        ;;
    Reboot)
        systemctl reboot 2>/dev/null || true
        ;;
esac
